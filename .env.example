# CutBook Backend — Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/cutbook

# Auth
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# Server
PORT=4000
NODE_ENV=development

# Africa's Talking (SMS/WhatsApp reminders)
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=sandbox

# App URL (for links in SMS messages)
APP_URL=http://localhost:3000
